{
  "name": "@authmodules/core",
  "version": "0.1.0",
  "description": "Headless identity orchestration core for TypeScript apps.",
  "keywords": [
    "auth",
    "authentication",
    "authmodules",
    "headless",
    "identity",
    "typescript"
  ],
  "homepage": "https://github.com/authmodules/core#readme",
  "bugs": {
    "url": "https://github.com/authmodules/core/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/authmodules/core.git"
  },
  "type": "module",
  "private": false,
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "npm@11.16.0",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm test && npm run build && npm run pack:dry",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "pack:dry": "npm pack --dry-run",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.7"
  }
}
